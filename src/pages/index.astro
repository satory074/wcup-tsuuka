---
import "../styles/globals.css";
import { siteLink } from "../lib/url";

// OG/Twitter 用の絶対URL（site=https://satory074.github.io, base=/wcup-tsuuka）
// siteLink() が base path と末尾スラッシュを正規化する。
const siteUrl = new URL(siteLink("/"), import.meta.env.SITE).toString();
const ogImage = new URL(siteLink("og.png"), import.meta.env.SITE).toString();
const ogTitle = "WCUP 通過タイムライン";
const ogDescription =
  "ワールドカップ グループステージの順位推移を、得点の瞬間まで時系列で可視化するサイト（2018 / 2022 / 2026）";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={siteLink("favicon.svg")} />
    <!-- 欧文の見出し（Barlow）と数字（Spline Sans Mono）のみ Web フォント化。和文はシステムフォント維持で軽量。 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Barlow+Semi+Condensed:wght@600;700;800&family=Spline+Sans+Mono:wght@500;600;700&display=swap"
    />
    <title>WCUP 通過タイムライン</title>
    <meta
      name="description"
      content="ワールドカップ グループステージの順位推移を、得点の瞬間まで時系列で可視化するサイト"
    />

    <!-- Open Graph / Twitter（SNS・基盤サイトのサムネ用） -->
    <link rel="canonical" href={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="WCUP 通過タイムライン" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <main id="app">
      <noscript>このアプリの利用には JavaScript が必要です。</noscript>
    </main>
    <nav class="app-backlink-bar" aria-label="サイト間ナビゲーション">
      <a
        href="https://satory074.com/apps/"
        target="_blank"
        rel="noopener"
        aria-label="satory074 のほかのアプリ一覧を新しいタブで開く"
        >satory074 のほかのアプリ <span aria-hidden="true">↗</span></a
      >
    </nav>
    <script>
      import { boot } from "../app/main";
      boot(document.getElementById("app")!);
    </script>
  </body>
</html>
